{"name":"How to Jet a Banshee","formula_count":0,"columns":[{"column":"E","hidden":true}],"rows":[{"index":2,"hidden":false,"cells":[{"coordinate":"B2","row":2,"column":2,"value":"How to Jet a Banshee (Two-Stroke)","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":24.0}}]},{"index":3,"hidden":false,"cells":[{"coordinate":"B3","row":3,"column":2,"value":"1. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C3","row":3,"column":3,"value":"Make sure the bike is in good mechanical order","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":4,"hidden":false,"cells":[{"coordinate":"C4","row":4,"column":3,"value":"No air leaks","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":5,"hidden":false,"cells":[{"coordinate":"C5","row":5,"column":3,"value":"Good compression","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":6,"hidden":false,"cells":[{"coordinate":"C6","row":6,"column":3,"value":"Good packing in the silencer(s)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":7,"hidden":false,"cells":[{"coordinate":"C7","row":7,"column":3,"value":"Good Reeds","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":8,"hidden":false,"cells":[{"coordinate":"C8","row":8,"column":3,"value":"Clean Filter(s)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":9,"hidden":false,"cells":[{"coordinate":"C9","row":9,"column":3,"value":"Fresh Plugs","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":10,"hidden":false,"cells":[{"coordinate":"B10","row":10,"column":2,"value":"2. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C10","row":10,"column":3,"value":"Mark the throttle positions (0 - 1/4 - 1/2 - 3/4 - Full)","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":11,"hidden":false,"cells":[{"coordinate":"C11","row":11,"column":3,"value":"Put some masking tape on the throttle housing so you can make 5 marks","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":12,"hidden":false,"cells":[{"coordinate":"C12","row":12,"column":3,"value":"Put some masking tape on the throttle (you only need to make a single mark)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":13,"hidden":false,"cells":[{"coordinate":"C13","row":13,"column":3,"value":"Mark the throttle housing and the throttle at the Closed (0) position","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":14,"hidden":false,"cells":[{"coordinate":"C14","row":14,"column":3,"value":"Mark the throttle housing at the Full (1) position","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":15,"hidden":false,"cells":[{"coordinate":"C15","row":15,"column":3,"value":"Mark the throttle housing at the 1/2 position (mark the center between 0 and 1)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":16,"hidden":false,"cells":[{"coordinate":"C16","row":16,"column":3,"value":"Mark the throttle housing at the 1/4 position (mark the center beteewn 0 and 1/2)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":17,"hidden":false,"cells":[{"coordinate":"C17","row":17,"column":3,"value":"Mark the throttle housing at the 3/4 position (mark the center beteewn 1/2 and 1)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":18,"hidden":false,"cells":[{"coordinate":"B18","row":18,"column":2,"value":"3. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C18","row":18,"column":3,"value":"Set the floats to 21mm","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":19,"hidden":false,"cells":[{"coordinate":"C19","row":19,"column":3,"value":"Measure when the carb is turned upside-down from the top of the float to the base of the gasket surface of the float bowl (without the gasket)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":20,"hidden":false,"cells":[{"coordinate":"C20","row":20,"column":3,"value":"Make sure the float tang does not compress the spring-loaded fuel inlet needle valve bumper during measuring","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":21,"hidden":false,"cells":[{"coordinate":"C21","row":21,"column":3,"value":"Install calculated main to start jetting","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":22,"hidden":false,"cells":[{"coordinate":"B22","row":22,"column":2,"value":"4. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C22","row":22,"column":3,"value":"Warm-up the bike","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":23,"hidden":false,"cells":[{"coordinate":"B23","row":23,"column":2,"value":"5. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C23","row":23,"column":3,"value":"Pilot Jet (0 to Full) [turn the air screw in to make it richer, out to make it leaner]","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":24,"hidden":false,"cells":[{"coordinate":"C24","row":24,"column":3,"value":"Turn the air screw all the way in, just until it's lightly seated, then set it 1.5-turns out","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":25,"hidden":false,"cells":[{"coordinate":"C25","row":25,"column":3,"value":"Slowly turn the air screw in, then out, until you find the fastest idle","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":26,"hidden":false,"cells":[{"coordinate":"C26","row":26,"column":3,"value":"If the air screw is less than 1-turn from Closed, it needs a larger pilot jet","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":27,"hidden":false,"cells":[{"coordinate":"C27","row":27,"column":3,"value":"If the air screw is  more than 2.5-turns from Closed, it needs a smaller pilot jet","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":28,"hidden":false,"cells":[{"coordinate":"C28","row":28,"column":3,"value":"Once you have determined and installed the correct pilot jet  and tuned the air screw for the fastest idle","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":29,"hidden":false,"cells":[{"coordinate":"C29","row":29,"column":3,"value":"Set the idle back down and ride the bike, using Closed to 1/4 throttle positions","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":30,"hidden":false,"cells":[{"coordinate":"C30","row":30,"column":3,"value":"Turn the air screw slightly (1/8 of a turn) in either direction until you find the point that gives you the best response when cracking the throttle open","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":31,"hidden":false,"cells":[{"coordinate":"B31","row":31,"column":2,"value":"6. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C31","row":31,"column":3,"value":"Needle Jet (1/4 to 3/4)","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":32,"hidden":false,"cells":[{"coordinate":"C32","row":32,"column":3,"value":"Ride the bike between the 1/4 and 3/4 marks","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":33,"hidden":false,"cells":[{"coordinate":"C33","row":33,"column":3,"value":"If the bike bogs for a second before responding to throttle, it's lean, lower the clip (raise the needle) a notch at a time until the engine runs smoothly","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":34,"hidden":false,"cells":[{"coordinate":"C34","row":34,"column":3,"value":"If the bike sputters or sounds rough when giving it throttle, it's rich, raise the clip (lower the needle) a notch at a time until the engine runs smoothly","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":35,"hidden":false,"cells":[{"coordinate":"B35","row":35,"column":2,"value":"7. ","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C35","row":35,"column":3,"value":"Main Jet (1/2 to Full)","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":36,"hidden":false,"cells":[{"coordinate":"C36","row":36,"column":3,"value":"Do a plug chop","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":37,"hidden":false,"cells":[{"coordinate":"C37","row":37,"column":3,"value":"Find a long straightaway","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":38,"hidden":false,"cells":[{"coordinate":"C38","row":38,"column":3,"value":"Install NEW plugs (mark each plug 'R' and 'L' to identify any cylinder differences)","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":39,"hidden":false,"cells":[{"coordinate":"C39","row":39,"column":3,"value":"Start the engine","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":40,"hidden":false,"cells":[{"coordinate":"C40","row":40,"column":3,"value":"Do a full-throttle run down the straightaway, through all the gears","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":41,"hidden":false,"cells":[{"coordinate":"C41","row":41,"column":3,"value":"As soon as the bike tops out, pull the clutch in, and kill the engine, and hit the brakes to stop","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":42,"hidden":false,"cells":[{"coordinate":"C42","row":42,"column":3,"value":"Remove the plugs","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":43,"hidden":false,"cells":[{"coordinate":"C43","row":43,"column":3,"value":"Put the original plugs back in and ride back","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":44,"hidden":false,"cells":[{"coordinate":"C44","row":44,"column":3,"value":"Chop and read the plugs","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":45,"hidden":false,"cells":[{"coordinate":"C45","row":45,"column":3,"value":"Look for a 2mm tall ring around the base of the porcelain","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":46,"hidden":false,"cells":[{"coordinate":"C46","row":46,"column":3,"value":"White or gray, the main is too lean","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":47,"hidden":false,"cells":[{"coordinate":"C47","row":47,"column":3,"value":"Dark brown or black, the main is too rich","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":48,"hidden":false,"cells":[{"coordinate":"C48","row":48,"column":3,"value":"Medium-dark mocha brown or tan, the main is perfect","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":50,"hidden":false,"cells":[{"coordinate":"B50","row":50,"column":2,"value":"☻","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}},{"coordinate":"C50","row":50,"column":3,"value":"Is it Rich or Lean?","formula":null,"cached":null,"locked":true,"font":{"bold":true,"size":11.0}}]},{"index":51,"hidden":false,"cells":[{"coordinate":"C51","row":51,"column":3,"value":"When an air-fuel mixture is too rich:","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":52,"hidden":false,"cells":[{"coordinate":"C52","row":52,"column":3,"value":"The engine noise is dull and intermittent","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":53,"hidden":false,"cells":[{"coordinate":"C53","row":53,"column":3,"value":"Condition worsens when the choke is opened","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":54,"hidden":false,"cells":[{"coordinate":"C54","row":54,"column":3,"value":"Condition worsens when the engine gets hot","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":55,"hidden":false,"cells":[{"coordinate":"C55","row":55,"column":3,"value":"Removal of the air cleaner improves the condition","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":56,"hidden":false,"cells":[{"coordinate":"C56","row":56,"column":3,"value":"Exhaust gases are heavy/oily","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":57,"hidden":false,"cells":[{"coordinate":"C57","row":57,"column":3,"value":"Plugs foul","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":58,"hidden":false,"cells":[{"coordinate":"C58","row":58,"column":3,"value":"When an air-fuel mixture is too lean:","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":59,"hidden":false,"cells":[{"coordinate":"C59","row":59,"column":3,"value":"Engine overheats","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":60,"hidden":false,"cells":[{"coordinate":"C60","row":60,"column":3,"value":"Condition improves when the choke is opened","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":61,"hidden":false,"cells":[{"coordinate":"C61","row":61,"column":3,"value":"Acceleration is poor","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":62,"hidden":false,"cells":[{"coordinate":"C62","row":62,"column":3,"value":"Engine RPMs fluctuate and lack of power is noticeable","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]},{"index":63,"hidden":false,"cells":[{"coordinate":"C63","row":63,"column":3,"value":"Plugs burn","formula":null,"cached":null,"locked":true,"font":{"bold":false,"size":11.0}}]}],"images":[]}
